{
  "uid": "agentops-gateway",
  "title": "AgentOps Gateway",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "정책 거부 카운트 (agent별)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (agent) (increase(gateway_policy_denied_total[5m]))",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "클라이언트별 호출량 (calls/s)",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (agent) (rate(gateway_tool_calls_total[1m]))",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency p50/p99 (tool별)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le, tool) (rate(gateway_tool_call_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{tool}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.99, sum by (le, tool) (rate(gateway_tool_call_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{tool}}"
        }
      ]
    }
  ]
}
